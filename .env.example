# API Tokens and Secrets
APIFY_API_TOKEN=your_apify_api_token_here
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEETS_CREDENTIALS=credentials.json

# SMTP / Email Outbox Config
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Snov.io API Credentials (Optional)
SNOV_CLIENT_ID=your_snov_client_id_here
SNOV_CLIENT_SECRET=your_snov_client_secret_here

# Gemini API Keys (Free and Paid tiers)
GEMINI_API_KEY_FREE=your_gemini_api_key_here
GEMINI_API_KEY_PAID=your_gemini_api_key_here

# Personalization configs (used by outbound scripts)
MASTER_RESUME_PDF_PATH=master_resume.pdf
SENDER_SIGNATURE="Your Name\nGrowth Marketing Strategist\nyour.email@example.com\nhttps://www.linkedin.com/in/yourprofile/"
SENDER_STATS="I'm a growth marketer with 4+ years of experience, having managed 20+ brands."
